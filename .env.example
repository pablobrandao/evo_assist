# Google AI (Gemini)
GEMINI_API_KEY=sua_chave_gemini_aqui
OPENROUTER_API_KEY=

# Embeddings locais
EMBEDDINGS_PROVIDER=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
LOCAL_EMBEDDING_PYTHON_BIN=python
LOCAL_EMBEDDING_CACHE_DIR=v2_data/huggingface

# Qdrant local
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=comercial-assistant
QDRANT_RECREATE_ON_DIMENSION_MISMATCH=true

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=minha_chave_interna_secreta

# Servidor Node.js
PORT=3000

# Email autorizado da empresa
COMPANY_EMAIL=admin@empresa.com

# Extracao de PDF (opcoes: local ou llamaparse)
PDF_PARSER_STRATEGY=local
LLAMACLOUD_API_KEY=

# Banco de dados
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/evolution?schema=public
